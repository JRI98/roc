# Cross-engine conformance for exact numeric literals: every executor must
# produce identical bits for these — they exercise correctly-rounded float
# conversion (ties-to-even, subnormals, overflow), exact Dec scaling, and
# integer boundary values.

f64_tie : F64
f64_tie = 9007199254740993

f64_odd_tie : F64
f64_odd_tie = 9007199254740995

f32_tie : F32
f32_tie = 16777217

f32_frac : F32
f32_frac = 0.1

f64_overflow : F64
f64_overflow = 1e400

f32_overflow : F32
f32_overflow = 1e39

deep_subnormal : F64
deep_subnormal = 0.

long_tail : F64
long_tail = 1.

tiny_dec : Dec
tiny_dec = 0.000000000000000001

max_dec : Dec
max_dec = 170141183460469231731.687303715884105727

min_dec : Dec
min_dec = -170141183460469231731.687303715884105728

i128_min : I128
i128_min = -170141183460469231731687303715884105728

u128_max : U128
u128_max = 340282366920938463463374607431768211455

neg_zero : F64
neg_zero = -0.0

expect f64_tie == 9007199254740992
expect f64_odd_tie == 9007199254740996
expect f32_tie == 16777216
expect f32_frac > 0.099
expect f32_frac < 0.101
expect f64_overflow > 1e308
expect f32_overflow > 3e38
expect deep_subnormal > 0
expect long_tail == 1
expect tiny_dec + tiny_dec == 0.000000000000000002
expect max_dec > 170141183460469231731.687303715884105726
expect min_dec < -170141183460469231731.687303715884105727
expect i128_min < -170141183460469231731687303715884105727
expect u128_max > 340282366920938463463374607431768211454
expect neg_zero == 0.0

main! = |_| {
    Ok({})
}
